<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="sk.spse.uloha5.declarative.Controller">

    <padding>
        <Insets topRightBottomLeft="15" />
    </padding>

    <top>
        <VBox alignment="CENTER">
            <padding>
                <Insets bottom="10" />
            </padding>
            <Label text="Zoznam potravín" style="-fx-font-size: 24px;" />
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" maxWidth="500">
            <TableView fx:id="tabulka" maxWidth="500" prefHeight="200">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="60" text="ID" />
                    <TableColumn fx:id="nazovColumn" prefWidth="200" text="Názov" />
                    <TableColumn fx:id="kalorieColumn" prefWidth="120" text="Kalórie" />
                    <TableColumn fx:id="cenaColumn" prefWidth="120" text="Cena" />
                </columns>
            </TableView>
        </HBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="5" />
            </padding>
            <Button text="Pridaj potravinu" onAction="#zobrazPridajDialog" />
            <Button text="Vymaž" onAction="#vymaz" />
            <Button text="Zatvor" onAction="#zatvor" />
        </HBox>
    </bottom>
</BorderPane>
